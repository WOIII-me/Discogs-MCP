{
  "name": "@woiii-me/discogs-mcp",
  "version": "1.3.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:token": "wrangler dev src/dev-server.ts --port 8787",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspect": "npx @modelcontextprotocol/inspector http://localhost:8787/mcp",
    "lint": "tsc --noEmit",
    "setup:kv": "wrangler kv namespace create OAUTH_KV && wrangler kv namespace create CACHE_KV"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260610.1",
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.99.0"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.7.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.15.0",
    "oauth-1.0a": "^2.2.6",
    "zod": "^4.4.3"
  }
}
