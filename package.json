{
  "name": "@woiii-me/discogs-mcp",
  "version": "1.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:token": "wrangler dev src/dev-server.ts --port 8787",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:submission": "node scripts/validate-openai-submission.mjs",
    "inspect": "npx @modelcontextprotocol/inspector http://localhost:8787/mcp",
    "lint": "tsc --noEmit",
    "setup:kv": "wrangler kv namespace create OAUTH_KV && wrangler kv namespace create CACHE_KV"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260723.1",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.113.0"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.18.0",
    "oauth-1.0a": "^2.2.6",
    "zod": "^4.4.3"
  }
}
